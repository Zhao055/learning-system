{
  "subject": "Mathematics 9709 - Statistics 1 (S1)",
  "subjectCn": "数学 9709 - 统计1",
  "chapters": [
    {
      "id": "s1_ch1",
      "title": "Data Representation",
      "titleCn": "数据表示",
      "knowledgePoints": [
        {
          "id": "s1_ch1_kp1",
          "title": "Histograms & Stem-and-Leaf",
          "titleCn": "直方图与茎叶图",
          "image": "",
          "questions": [
            {
              "id": "q2_1_01",
              "stem": "A histogram shows a bar for the class interval 20 ≤ x < 30 with a frequency density of 3.5. What is the frequency for this class?",
              "options": [
                "35",
                "3.5",
                "350",
                "0.35"
              ],
              "correctIndex": 0,
              "explanation": "Frequency = Frequency Density × Class Width = 3.5 × 10 = 35.",
              "difficulty": "easy"
            },
            {
              "id": "q2_1_02",
              "stem": "A frequency table shows 24 values in the class 10 ≤ x < 16. What is the frequency density for this class?",
              "options": [
                "4",
                "24",
                "6",
                "0.25"
              ],
              "correctIndex": 0,
              "explanation": "Class width = 16 − 10 = 6. Frequency density = Frequency / Class Width = 24 / 6 = 4.",
              "difficulty": "easy"
            },
            {
              "id": "q2_1_03",
              "stem": "A stem-and-leaf diagram has stems 3, 4, 5 with leaves: 3|1 2 5 8, 4|0 3 6 6 9, 5|2 4. How many values are greater than 45?",
              "options": [
                "5",
                "4",
                "7",
                "3"
              ],
              "correctIndex": 0,
              "explanation": "Values greater than 45: from stem 4 — leaves 6, 6, 9 (giving 46, 46, 49) and from stem 5 — leaves 2, 4 (giving 52, 54). That is 3 + 2 = 5 values.",
              "difficulty": "medium"
            }
          ]
        }
      ]
    },
    {
      "id": "s1_ch2",
      "title": "Permutations & Combinations",
      "titleCn": "排列组合",
      "knowledgePoints": [
        {
          "id": "s1_ch2_kp1",
          "title": "Counting Methods",
          "titleCn": "计数方法",
          "image": "",
          "questions": [
            {
              "id": "q2_2_01",
              "stem": "How many ways can 4 students be chosen from a group of 9 to form a committee?",
              "options": [
                "126",
                "3024",
                "36",
                "84"
              ],
              "correctIndex": 0,
              "explanation": "This is a combination (order does not matter): ⁹C₄ = 9! / (4! × 5!) = (9 × 8 × 7 × 6) / (4 × 3 × 2 × 1) = 3024 / 24 = 126.",
              "difficulty": "easy"
            },
            {
              "id": "q2_2_02",
              "stem": "How many different 3-letter arrangements can be made from the letters of the word MATHS (no repetition)?",
              "options": [
                "60",
                "10",
                "120",
                "15"
              ],
              "correctIndex": 0,
              "explanation": "This is a permutation (order matters): ⁵P₃ = 5! / (5−3)! = 5! / 2! = 120 / 2 = 60.",
              "difficulty": "easy"
            },
            {
              "id": "q2_2_03",
              "stem": "A team of 3 is chosen from 5 men and 4 women, with at least 1 woman required. How many possible teams are there?",
              "options": [
                "74",
                "84",
                "10",
                "60"
              ],
              "correctIndex": 0,
              "explanation": "Total ways without restriction = ⁹C₃ = 84. Ways with NO women (all men) = ⁵C₃ = 10. Teams with at least 1 woman = 84 − 10 = 74.",
              "difficulty": "medium"
            }
          ]
        }
      ]
    },
    {
      "id": "s1_ch3",
      "title": "Probability",
      "titleCn": "概率",
      "knowledgePoints": [
        {
          "id": "s1_ch3_kp1",
          "title": "Conditional Probability",
          "titleCn": "条件概率",
          "image": "",
          "questions": [
            {
              "id": "q2_3_01",
              "stem": "P(A) = 0.6, P(B) = 0.5, P(A ∩ B) = 0.3. What is P(A | B)?",
              "options": [
                "0.6",
                "0.5",
                "0.3",
                "0.18"
              ],
              "correctIndex": 0,
              "explanation": "P(A | B) = P(A ∩ B) / P(B) = 0.3 / 0.5 = 0.6.",
              "difficulty": "easy"
            },
            {
              "id": "q2_3_02",
              "stem": "A bag contains 3 red and 5 blue balls. Two balls are drawn without replacement. What is the probability that both are red?",
              "options": [
                "3/28",
                "9/64",
                "3/8",
                "1/4"
              ],
              "correctIndex": 0,
              "explanation": "P(1st red) = 3/8. Given 1st is red, P(2nd red) = 2/7. So P(both red) = (3/8) × (2/7) = 6/56 = 3/28.",
              "difficulty": "medium"
            },
            {
              "id": "q2_3_03",
              "stem": "Events A and B are such that P(A) = 0.4, P(B) = 0.3, and A and B are independent. What is P(A ∪ B)?",
              "options": [
                "0.58",
                "0.70",
                "0.12",
                "0.50"
              ],
              "correctIndex": 0,
              "explanation": "Since A and B are independent, P(A ∩ B) = P(A) × P(B) = 0.4 × 0.3 = 0.12. P(A ∪ B) = P(A) + P(B) − P(A ∩ B) = 0.4 + 0.3 − 0.12 = 0.58.",
              "difficulty": "medium"
            }
          ]
        }
      ]
    },
    {
      "id": "s1_ch4",
      "title": "Discrete Random Variables",
      "titleCn": "离散随机变量",
      "knowledgePoints": [
        {
          "id": "s1_ch4_kp1",
          "title": "Expected Value & Variance",
          "titleCn": "期望值与方差",
          "image": "",
          "questions": [
            {
              "id": "q2_4_01",
              "stem": "A discrete random variable X has the distribution: P(X=1)=0.2, P(X=2)=0.5, P(X=3)=0.3. What is E(X)?",
              "options": [
                "2.1",
                "2.0",
                "1.5",
                "2.5"
              ],
              "correctIndex": 0,
              "explanation": "E(X) = Σ x·P(X=x) = 1(0.2) + 2(0.5) + 3(0.3) = 0.2 + 1.0 + 0.9 = 2.1.",
              "difficulty": "easy"
            },
            {
              "id": "q2_4_02",
              "stem": "Using the distribution in the previous question (P(X=1)=0.2, P(X=2)=0.5, P(X=3)=0.3), what is Var(X)?",
              "options": [
                "0.49",
                "2.1",
                "1.0",
                "0.7"
              ],
              "correctIndex": 0,
              "explanation": "E(X²) = 1²(0.2) + 2²(0.5) + 3²(0.3) = 0.2 + 2.0 + 2.7 = 4.9. Var(X) = E(X²) − [E(X)]² = 4.9 − (2.1)² = 4.9 − 4.41 = 0.49.",
              "difficulty": "medium"
            },
            {
              "id": "q2_4_03",
              "stem": "If E(X) = 3 and Var(X) = 4, what is E(2X + 1)?",
              "options": [
                "7",
                "9",
                "13",
                "4"
              ],
              "correctIndex": 0,
              "explanation": "E(2X + 1) = 2·E(X) + 1 = 2(3) + 1 = 6 + 1 = 7.",
              "difficulty": "easy"
            }
          ]
        }
      ]
    },
    {
      "id": "s1_ch5",
      "title": "Normal Distribution",
      "titleCn": "正态分布",
      "knowledgePoints": [
        {
          "id": "s1_ch5_kp1",
          "title": "Standard Normal Distribution",
          "titleCn": "标准正态分布",
          "image": "",
          "questions": [
            {
              "id": "q2_5_01",
              "stem": "X ~ N(50, 16). What is the z-score corresponding to x = 54?",
              "options": [
                "1",
                "4",
                "0.25",
                "2"
              ],
              "correctIndex": 0,
              "explanation": "The variance is 16, so the standard deviation σ = √16 = 4. z = (x − μ) / σ = (54 − 50) / 4 = 4 / 4 = 1.",
              "difficulty": "easy"
            },
            {
              "id": "q2_5_02",
              "stem": "X ~ N(100, 25). Using the standard normal table, P(X < 110) = Φ(2) ≈ 0.9772. What is P(X > 110)?",
              "options": [
                "0.0228",
                "0.9772",
                "0.5",
                "0.4772"
              ],
              "correctIndex": 0,
              "explanation": "σ = √25 = 5. z = (110 − 100) / 5 = 2. P(X < 110) = Φ(2) ≈ 0.9772. P(X > 110) = 1 − 0.9772 = 0.0228.",
              "difficulty": "easy"
            },
            {
              "id": "q2_5_03",
              "stem": "X ~ N(μ, 9). It is given that P(X < 17) = 0.9332, and Φ(1.5) = 0.9332. What is the value of μ?",
              "options": [
                "12.5",
                "14",
                "17",
                "15.5"
              ],
              "correctIndex": 0,
              "explanation": "σ = √9 = 3. Since P(X < 17) = 0.9332 = Φ(1.5), the z-score is 1.5. So (17 − μ) / 3 = 1.5, giving 17 − μ = 4.5, thus μ = 12.5.",
              "difficulty": "medium"
            }
          ]
        }
      ]
    }
  ]
}
