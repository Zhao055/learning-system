# 知芽服务端环境变量
# AI 网关优先级：Synapse > Claude > MiniMax，至少配一个

# 服务端口（默认 3000）
PORT=3000

# 方式 1: Synapse SDK（推荐，走统一网关）
# SYNAPSE_URL=https://your-synapse-endpoint
# SYNAPSE_API_KEY=your-synapse-api-key

# 方式 2: Claude 直连
# ANTHROPIC_API_KEY=sk-ant-xxx

# 方式 3: MiniMax 直连
# MINIMAX_API_KEY=your-minimax-api-key

# JWT 密钥（必填）
JWT_SECRET=change-me-to-a-random-string
